#!/usr/bin/env bash
# gstack-windsurf — Browse wrapper for Windsurf/Cascade environment
# This script provides a convenient interface to gstack's browse binary
# from within the Windsurf IDE for Salesforce development.

set -e

GSTACK_DIR="$HOME/Repositories/gstack"
BROWSE_BIN="$GSTACK_DIR/browse/dist/browse"
PLM_DIR="$HOME/Repositories/PLM"
GSTACK_DIR_PLM="$PLM_DIR/.gstack"

# Ensure PATH includes bun
export PATH="$HOME/.bun/bin:$PATH"

# Function to show usage
show_usage() {
    cat << 'EOF'
Usage: gstack-windsurf <command> [args...]

Salesforce-aware browsing commands:
  goto-org [org-alias]     Navigate to Salesforce dev org login
  login [org-alias]        Login to Salesforce org (uses sf CLI for session)
  wait-for-load [timeout]  Wait for page to fully load (handles Lightning spinners)
  find-item <item-number> [org-alias]  Find item by item number using SOQL and navigate to it
  screenshot [path]        Take screenshot of current page
  browse <args...>         Pass through to browse binary

Standard browse commands (pass-through):
  goto <url>               Navigate to URL
  click <selector>         Click element
  fill <selector> <text>   Fill input field
  snapshot [-i]            Get page snapshot with element refs
  text                     Get page text content
  console                  Get browser console logs
  cookies                  Get/set cookies

Examples:
  gstack-windsurf goto-org mydevorg
  gstack-windsurf wait-for-load 30
  gstack-windsurf find-item 0000001-00-01 mydevorg
  gstack-windsurf login mydevorg
  gstack-windsurf screenshot /tmp/home.png
  gstack-windsurf browse goto https://mydevorg.salesforce.com

Environment:
  GSTACK_DIR    Override gstack installation directory
  BROWSE_BIN    Override browse binary path
EOF
}

# Get item ID by item number using SOQL
get_item_id_by_number() {
    local item_number="$1"
    local org_alias="${2:-}"

    # Get default org if not specified
    if [ -z "$org_alias" ]; then
        org_alias=$(get_default_org_alias)
        echo "Using default org: $org_alias" >&2
    fi

    # Get namespace for this org
    namespace=$(get_namespace "$org_alias")
    if [ -n "$namespace" ]; then
        object_name="${namespace}__Item__c"
    else
        # Assume production org with managed package namespace
        object_name="PDLM__Item__c"
    fi

    # Use sf CLI to query for the item
    query_result=$(sf data query --query "SELECT Id FROM $object_name WHERE Name = '$item_number' LIMIT 1" --target-org "$org_alias" --json 2>/dev/null)

    # Extract the ID from the JSON result
    item_id=$(echo "$query_result" | grep -o '"Id"[[:space:]]*:[[:space:]]*"[^"]*"' | cut -d'"' -f4 | head -1)

    if [ -n "$item_id" ]; then
        echo "$item_id"
    else
        echo ""
    fi
}

# Get Salesforce org URL from sf CLI
get_org_url() {
    local org_alias="${1:-}"
    if [ -n "$org_alias" ]; then
        org_url=$(sf org display --target-org "$org_alias" --json 2>/dev/null | jq -r '.result.instanceUrl // empty')
        echo "$org_url"
    else
        # Try to get default org
        org_url=$(sf org display --json 2>/dev/null | jq -r '.result.instanceUrl // empty')
        echo "$org_url"
    fi
}

# Get namespace from Organization object
get_namespace() {
    local org_alias="${1:-}"
    if [ -n "$org_alias" ]; then
        namespace=$(sf data query --query "SELECT NamespacePrefix FROM Organization LIMIT 1" --target-org "$org_alias" --json 2>/dev/null | jq -r '.result.records[0].NamespacePrefix // empty')
        echo "$namespace"
    else
        # Try default org
        namespace=$(sf data query --query "SELECT NamespacePrefix FROM Organization LIMIT 1" --json 2>/dev/null | jq -r '.result.records[0].NamespacePrefix // empty')
        echo "$namespace"
    fi
}

# Get org alias from sf CLI
get_default_org_alias() {
    sf org list --json 2>/dev/null | jq -r '.result[0].alias // empty'
}

# Main command handler
case "${1:-}" in
    --help|-h|help)
        show_usage
        exit 0
        ;;

    goto-org)
        org_alias="${2:-}"
        if [ -z "$org_alias" ]; then
            org_alias=$(get_default_org_alias)
            echo "Using default org: $org_alias"
        fi

        org_url=$(get_org_url "$org_alias")
        if [ -z "$org_url" ]; then
            echo "Error: Could not get org URL. Ensure you're authenticated with 'sf org login'" >&2
            exit 1
        fi

        echo "Navigating to: $org_url"
        cd "$PLM_DIR" && "$BROWSE_BIN" goto "$org_url"
        ;;

    login)
        org_alias="${2:-}"
        org_url=$(get_org_url "$org_alias")

        if [ -z "$org_url" ]; then
            echo "Error: Could not get org URL" >&2
            exit 1
        fi

        echo "Opening Salesforce login at: $org_url"
        echo "After login completes, cookies will be preserved for the session."
        cd "$PLM_DIR" && "$BROWSE_BIN" goto "$org_url"

        # Wait a moment and take initial screenshot
        sleep 2
        echo ""
        echo "Use 'gstack-windsurf screenshot /tmp/salesforce.png' to capture the page"
        ;;

    screenshot)
        path="${2:-/tmp/salesforce-$(date +%Y%m%d-%H%M%S).png}"
        echo "Waiting for page to load..."
        sleep 3
        echo "Taking screenshot: $path"
        cd "$PLM_DIR" && "$BROWSE_BIN" screenshot "$path"
        echo "Screenshot saved: $path"
        ;;

    browse)
        # Pass all remaining args to browse binary
        shift
        cd "$PLM_DIR" && "$BROWSE_BIN" "$@"
        ;;

    wait-for-load)
        # Wait for page to fully load (handles Lightning loading spinners)
        # Usage: wait-for-load [timeout-seconds]
        timeout="${2:-30}"

        echo "Waiting for page to load (timeout: ${timeout}s)..."

        # Initial wait for basic page load
        sleep 3

        # Wait for Lightning spinner to disappear
        echo "Checking for Lightning loading spinners..."
        for i in $(seq 1 $((timeout/3))); do
            spinner_status=$(cd "$PLM_DIR" && "$BROWSE_BIN" js "document.querySelector('.slds-spinner') ? 'loading' : 'loaded'" 2>/dev/null || echo "error")

            if [ "$spinner_status" = "loaded" ]; then
                echo "Page loaded successfully (spinner disappeared)"
                break
            fi

            echo "Still loading... ($((i*3))s elapsed)"
            sleep 3
        done

        # Additional wait for dynamic content
        echo "Waiting for dynamic content..."
        sleep 5

        # Final check
        final_check=$(cd "$PLM_DIR" && "$BROWSE_BIN" js "document.readyState" 2>/dev/null || echo "unknown")
        echo "Document ready state: $final_check"

        # Check for any remaining loading indicators
        remaining_loaders=$(cd "$PLM_DIR" && "$BROWSE_BIN" js "document.querySelectorAll('.slds-spinner, .loading, .spinner').length" 2>/dev/null || echo "0")
        echo "Remaining loading indicators: $remaining_loaders"

        if [ "$remaining_loaders" = "0" ]; then
            echo "✅ Page appears to be fully loaded"
        else
            echo "⚠️  Page may still be loading (proceeding anyway)"
        fi
        ;;

    find-item)
        # Find item by item number using SOQL and navigate to it
        # Usage: find-item <item-number> [org-alias]
        item_number="${2:-}"
        org_alias="${3:-}"

        if [ -z "$item_number" ]; then
            echo "Error: Item number required" >&2
            echo "Usage: find-item <item-number> [org-alias]" >&2
            exit 1
        fi

        # Get item ID using SOQL (redirect debug output to stderr)
        item_id=$(get_item_id_by_number "$item_number" "$org_alias" 2>/dev/null)

        if [ -z "$item_id" ]; then
            echo "Error: Item '$item_number' not found" >&2
            exit 1
        fi


        # Navigate to the item using the existing goto-record function
        echo "Navigating to item..."
        "$0" goto-record "$item_id" "$org_alias"

        # Wait for item page to load
        echo "Waiting for item page to load..."
        "$0" wait-for-load 30

        echo "✅ Successfully navigated to item: $item_number (ID: $item_id)"

        # Take screenshot of the loaded item page
        screenshot_path="/tmp/item-$item_number-$(date +%Y%m%d-%H%M%S).png"
        echo "Taking screenshot: $screenshot_path"
        "$0" screenshot "$screenshot_path"
        echo "Screenshot saved: $screenshot_path"
        ;;

    goto-record)
        # Navigate to a Salesforce record page
        # Usage: goto-record <record-id> [org-alias]
        record_id="${2:-}"
        org_alias="${3:-ron@plm20160415.dev}"

        if [ -z "$record_id" ]; then
            echo "Error: Record ID required" >&2
            echo "Usage: goto-record <record-id> [org-alias]" >&2
            exit 1
        fi

        # Get org info using JSON
        org_info=$(sf org display --target-org "$org_alias" --json 2>/dev/null || echo "{}")
        if [ "$org_info" = "{}" ]; then
            echo "Error: Could not get org info for $org_alias" >&2
            exit 1
        fi

        # Extract instance URL and access token using jq
        instance_url=$(echo "$org_info" | jq -r '.result.instanceUrl // empty')
        access_token=$(echo "$org_info" | jq -r '.result.accessToken // empty')

        if [ -z "$instance_url" ] || [ -z "$access_token" ]; then
            echo "Error: Could not get instance URL or access token" >&2
            exit 1
        fi

        # Get namespace from Organization object
        namespace=$(get_namespace "$org_alias")
        if [ -z "$namespace" ]; then
            echo "Warning: Could not determine namespace, assuming production org with PDLM namespace" >&2
            namespace="PDLM"
        else
            echo "Using namespace: ${namespace}"
        fi

        # Convert to Lightning URL
        # Extract the domain part (e.g., hess-dev-ed.my.salesforce.com)
        domain=$(echo "$instance_url" | sed 's|https://||' | sed 's|/||g')
        lightning_domain=$(echo "$domain" | sed 's|.my.salesforce.com|.lightning.force.com|')

        # Build Lightning record URL with namespace
        record_url="https://${lightning_domain}/lightning/r/${namespace}__Item__c/${record_id}/view"

        echo "Setting authentication cookie..."
        # Set the sid cookie on the salesforce.com domain first
        cd "$PLM_DIR" && "$BROWSE_BIN" goto "$instance_url" 2>/dev/null || true
        cd "$PLM_DIR" && "$BROWSE_BIN" cookie "sid=${access_token}" 2>/dev/null || true

        echo "Navigating to: $record_url"
        cd "$PLM_DIR" && "$BROWSE_BIN" goto "$record_url"
        ;;

    record-screenshot)
        # Navigate to record and take screenshot
        record_id="${2:-}"
        org_alias="${3:-ron@plm20160415.dev}"

        if [ -z "$record_id" ]; then
            echo "Error: Record ID required" >&2
            echo "Usage: record-screenshot <record-id> [org-alias]" >&2
            exit 1
        fi

        # Navigate to record
        "$0" goto-record "$record_id" "$org_alias"

        # Wait for page load
        "$0" wait-for-load 20

        # Take screenshot
        output_path="/tmp/record-${record_id}-$(date +%Y%m%d-%H%M%S).png"
        echo "Taking screenshot: $output_path"
        cd "$PLM_DIR" && "$BROWSE_BIN" screenshot "$output_path"
        echo "Screenshot saved: $output_path"
        ;;
esac
